{
  "$schema": "node_modules/wrangler/config-schema.json",
  "main": ".open-next/worker.js",
  "name": "ui-grvx",
  "compatibility_date": "2026-06-09",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "build": {
    "command": "pnpm run build-cf"
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "ui-grvx"
    }
  ],

  "images": {
    "binding": "IMAGES"
  },
  "observability": {
    "enabled": true
  }
}
